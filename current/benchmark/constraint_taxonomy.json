  "constraint_pool": {
    "design": "hard约束定义为checker×参数空间，采样时抽checker+参数组合，文本由LLM根据query语境动态生成。soft约束保持模板池。",
    "slots": {
      "description": "每条case从4个slot各选1个约束，确保长度+结构+多样化IF+风格全覆盖",
      "1_length": {
        "name_cn": "长度约束",
        "pick": 1,
        "type": "hard"
      },
      "2_structure": {
        "name_cn": "结构约束",
        "pick": 1,
        "type": "hard"
      },
      "3_diverse": {
        "name_cn": "多样化IF约束",
        "pick": 1,
        "type": "hard"
      },
      "4_soft": {
        "name_cn": "软性IF约束",
        "pick": 1,
        "type": "soft"
      }
    },
    "hard_checkers": {
      "_note": "每个checker定义参数空间+所属slot。采样时：(1)选slot→(2)选checker→(3)从参数空间采样→(4)LLM生成约束文本",
      "check_word_range": {
        "tag": "N1",
        "slot": "1_length",
        "inv": false,
        "param_space": {
          "min_words": {
            "type": "int",
            "range": [
              100,
              1000
            ],
            "step": 50
          },
          "max_words": {
            "type": "int",
            "relative_to": "min_words",
            "offset": [
              100,
              500
            ],
            "step": 50
          }
        },
        "task_defaults": {
          "T1": {
            "min_words": [
              200,
              400
            ],
            "max_words_offset": [
              150,
              300
            ]
          },
          "T2": {
            "min_words": [
              400,
              600
            ],
            "max_words_offset": [
              200,
              400
            ]
          },
          "T3": {
            "min_words": [
              600,
              1000
            ],
            "max_words_offset": [
              200,
              500
            ]
          }
        },
        "text_hint": "控制在{min_words}到{max_words}字"
      },
      "check_word_limit": {
        "tag": "N1",
        "slot": "1_length",
        "inv": false,
        "param_space": {
          "max_words": {
            "type": "int",
            "range": [
              200,
              1500
            ],
            "step": 50
          }
        },
        "task_defaults": {
          "T1": {
            "max_words": [
              300,
              600
            ]
          },
          "T2": {
            "max_words": [
              500,
              1000
            ]
          },
          "T3": {
            "max_words": [
              800,
              1500
            ]
          }
        },
        "text_hint": "不超过{max_words}字"
      },
      "check_sentence_count": {
        "tag": "N2",
        "slot": "1_length",
        "inv": false,
        "param_space": {
          "min_count": {
            "type": "int",
            "range": [
              5,
              30
            ]
          }
        },
        "task_defaults": {
          "T1": {
            "min_count": [
              5,
              12
            ]
          },
          "T2": {
            "min_count": [
              10,
              20
            ]
          },
          "T3": {
            "min_count": [
              12,
              25
            ]
          }
        },
        "text_hint": "至少{min_count}个完整句子"
      },
      "check_paragraph_count": {
        "tag": "N2",
        "slot": "1_length",
        "inv": false,
        "param_space": {
          "min_count": {
            "type": "int",
            "range": [
              2,
              10
            ]
          },
          "max_count": {
            "type": "int",
            "relative_to": "min_count",
            "offset": [
              1,
              4
            ]
          }
        },
        "task_defaults": {
          "T1": {
            "min_count": [
              3,
              5
            ]
          },
          "T2": {
            "min_count": [
              4,
              7
            ]
          },
          "T3": {
            "min_count": [
              5,
              9
            ]
          }
        },
        "text_hint": "分为{min_count}到{max_count}个段落"
      },
      "check_section_count": {
        "tag": "F1",
        "slot": "2_structure",
        "inv": false,
        "param_space": {
          "min_sections": {
            "type": "int",
            "range": [
              2,
              6
            ]
          }
        },
        "task_defaults": {
          "T1": {
            "min_sections": [
              2,
              3
            ]
          },
          "T2": {
            "min_sections": [
              3,
              4
            ]
          },
          "T3": {
            "min_sections": [
              3,
              5
            ]
          }
        },
        "text_hint": "至少{min_sections}个独立章节"
      },
      "check_heading_level": {
        "tag": "F1",
        "slot": "2_structure",
        "inv": false,
        "param_space": {
          "level": {
            "type": "int",
            "options": [
              2,
              3
            ]
          },
          "min_count": {
            "type": "int",
            "range": [
              2,
              5
            ]
          }
        },
        "text_hint": "{min_count}个{level}级标题"
      },
      "check_heading_depth": {
        "tag": "F1",
        "slot": "2_structure",
        "inv": false,
        "param_space": {
          "min_depth": {
            "type": "int",
            "options": [
              2,
              3
            ]
          }
        },
        "text_hint": "使用至少{min_depth}层标题层级"
      },
      "check_ordered_list_count": {
        "tag": "F2",
        "slot": "2_structure",
        "inv": false,
        "param_space": {
          "min_count": {
            "type": "int",
            "range": [
              3,
              8
            ]
          },
          "max_count": {
            "type": "int",
            "relative_to": "min_count",
            "offset": [
              1,
              4
            ]
          }
        },
        "text_hint": "{min_count}到{max_count}条有序列表"
      },
      "check_markdown_table": {
        "tag": "F3",
        "slot": "2_structure",
        "inv": false,
        "param_space": {},
        "text_hint": "使用Markdown表格展示数据"
      },
      "check_blockquote_count": {
        "tag": "F5",
        "slot": "2_structure",
        "inv": false,
        "param_space": {
          "min_count": {
            "type": "int",
            "range": [
              1,
              4
            ]
          }
        },
        "applicable_tasks": [
          "T1",
          "T2"
        ],
        "text_hint": "至少{min_count}处引用块"
      },
      "check_first_last_line": {
        "tag": "F6",
        "slot": "2_structure",
        "inv": false,
        "param_space": {
          "first_line": {
            "type": "string",
            "examples": [
              "摘要",
              "概要"
            ]
          },
          "last_line": {
            "type": "string",
            "optional": true,
            "examples": [
              "以上内容仅供参考",
              "---"
            ]
          }
        },
        "text_hint": "首行包含\"{first_line}\"，末行包含\"{last_line}\""
      },
      "check_no_table": {
        "tag": "F3",
        "slot": "2_structure",
        "inv": true,
        "param_space": {},
        "max_uses_per_100": 8,
        "text_hint": "不使用表格"
      },
      "check_no_list": {
        "tag": "F2",
        "slot": "2_structure",
        "inv": true,
        "param_space": {},
        "max_uses_per_100": 8,
        "text_hint": "不使用列表"
      },
      "check_forbidden_pattern": {
        "tag": "L2",
        "slot": "3_diverse",
        "inv": false,
        "param_space": {
          "forbidden": {
            "type": "string_list",
            "pool": [
              [
                "！",
                "!"
              ],
              [
                "投资建议",
                "建议买入",
                "建议卖出",
                "建议持有"
              ],
              [
                "个人观点",
                "我认为",
                "我觉得"
              ],
              [
                "（注",
                "（备注",
                "注：",
                "备注："
              ],
              [
                "综上所述",
                "总而言之"
              ],
              [
                "首先",
                "其次",
                "最后"
              ],
              [
                "然而",
                "但是",
                "不过"
              ],
              [
                "众所周知",
                "显而易见"
              ]
            ]
          }
        },
        "text_hint": "不使用{forbidden_desc}"
      },
      "check_first_word": {
        "tag": "F6",
        "slot": "3_diverse",
        "inv": false,
        "param_space": {
          "word": {
            "type": "string",
            "pool": [
              "总结",
              "根据",
              "从",
              "截至",
              "综合",
              "基于",
              "鉴于"
            ]
          }
        },
        "text_hint": "开头第一个词必须是\"{word}\""
      },
      "check_first_person": {
        "tag": "L2",
        "slot": "3_diverse",
        "inv": true,
        "param_space": {
          "forbidden_phrases": {
            "type": "string_list",
            "default": [
              "本报告",
              "本文",
              "本分析",
              "本研究",
              "报告认为"
            ]
