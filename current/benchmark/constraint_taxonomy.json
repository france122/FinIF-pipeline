    "mixing_rules": {
      "per_case": "4-6 constraints (4 from slots + 0-2 retained correctness constraints)",
      "sampling": "diversity-weighted: (1) select slot → (2) select checker from slot → (3) sample params from param_space → (4) LLM generates constraint text given query context and checker+params",
      "inv_limits": "INV checkers have max_uses_per_100 caps",
      "text_generation": "hard约束文本由LLM根据query语境生成，需确保语义与checker+params对齐。生成后可用text_hint做一致性校验。"
