{
  "scoring": {
    "description": "FinIF双轴评测框架：模型在每条case上独立报两个分，汇总时分别呈现",
    "axes": {
      "compliance": {
        "label_en": "Compliance",
        "label_cn": "遵从性",
        "description": "指令听没听。格式（表格/章节/JSON）、篇幅（字数）、用词（禁止模式/术语）、风格（语气/角色）是否按要求输出。",
        "criterion": "检查'输出长什么样'",
        "tags": [
          "F1",
          "F2",
          "F3",
          "F4",
          "F5",
          "F6",
          "F7",
          "F8",
          "N1",
          "N2",
          "N3",
          "N4",
          "L1",
          "L2",
          "L3",
          "L4",
          "S1",
          "S2",
          "S3",
          "S4",
          "C1",
          "C2",
          "C3",
          "C4",
          "C5"
        ]
      },
      "correctness": {
        "label_en": "Correctness",
        "label_cn": "正确性",
        "description": "内容对不对。计算结果、数据提取、推导过程是否准确。有ground truth，程序化验证。",
        "criterion": "检查'输出算没算对'",
        "tags": [
          "C6"
        ]
      }
    },
    "constraint_types": {
      "hard": "程序checker验证，确定性pass/fail",
      "soft": "LLM judge评分，基于rubric判断pass/fail"
    }
  },
